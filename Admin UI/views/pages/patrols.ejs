<!-- Patrols Page -->
<div class="page-header">
    <div class="page-header-left">
        <h1><i data-lucide="map-pin" style="width:32px;height:32px;color:var(--primary)"></i> Active Patrols</h1>
        <p>Real-time ranger deployment and coordination</p>
    </div>
    <button class="btn btn-primary">Schedule New Patrol</button>
</div>

<!-- Summary Stats -->
<div class="grid grid-cols-4">
    <div class="card card-compact">
        <p class="text-sm text-muted mb-2">Active Patrols</p>
        <p class="text-2xl font-bold text-primary">4</p>
    </div>
    <div class="card card-compact">
        <p class="text-sm text-muted mb-2">Total Rangers</p>
        <p class="text-2xl font-bold text-foreground">16</p>
    </div>
    <div class="card card-compact">
        <p class="text-sm text-muted mb-2">Avg Coverage</p>
        <p class="text-2xl font-bold text-success">88%</p>
    </div>
    <div class="card card-compact">
        <p class="text-sm text-muted mb-2">Total Detections</p>
        <p class="text-2xl font-bold text-destructive">5</p>
    </div>
</div>

<!-- Patrol Map -->
<div class="patrol-map-placeholder">
    <h3>Patrol Routes - Mudumalai Reserve</h3>
    <p>5 patrol teams deployed across operational zones</p>
</div>

