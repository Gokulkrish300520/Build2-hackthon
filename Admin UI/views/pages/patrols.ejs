<!-- Communication Status -->
<div class="system-status">
    <h3><i data-lucide="radio" style="width:20px;height:20px;color:var(--primary)"></i> Ranger Communication Status</h3>
    <div class="system-status-grid">
        <div class="system-status-item">
            <p class="label">LoRa Signal</p>
            <div class="status-row"><span class="dot"></span><span>Strong</span></div>
        </div>
        <div class="system-status-item">
            <p class="label">Avg Latency</p><span class="font-semibold">120ms</span>
        </div>
        <div class="system-status-item">
            <p class="label">Uptime</p><span class="font-semibold text-success">99.8%</span>
        </div>
        <div class="system-status-item">
            <p class="label">Last Sync</p><span class="font-semibold">2 seconds ago</span>
        </div>
    </div>
