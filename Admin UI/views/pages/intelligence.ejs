<!-- Intelligence Page -->
<div class="page-header">
    <div class="page-header-left">
        <h1><i data-lucide="trending-up" style="width:32px;height:32px;color:var(--primary)"></i> Predictive
            Intelligence</h1>
        <p>Historical patterns and behavioral analysis</p>
    </div>
    <button class="btn btn-primary">Generate Intelligence Report</button>
</div>

<!-- Key Insights -->
<div class="grid grid-cols-3">
    <div class="insight-card destructive">
        <p class="insight-label text-destructive">Critical Trend</p>
        <p class="insight-value">+47%</p>
        <p class="insight-sub">Increase in poaching attempts (YoY)</p>
    </div>
    <div class="insight-card warning">
        <p class="insight-label text-warning">Peak Risk Period</p>
        <p class="insight-value text-lg">Dry Season (Jun-Oct)</p>
        <p class="insight-sub">87% higher incident rate</p>
    </div>
    <div class="insight-card primary">
        <p class="insight-label text-primary">High Risk Zone</p>
        <p class="insight-value text-lg">Northern Corridor</p>
        <p class="insight-sub">Consistent hotspot for threats</p>
    </div>
</div>

<!-- Trends Chart -->
<div class="chart-card">
    <h3>6-Month Trend Analysis</h3>
    <div class="chart-container" style="height:350px">
        <canvas id="trendChart"></canvas>
    </div>
</div>

<!-- Side by side charts -->
<div class="grid grid-cols-2">
    <div class="chart-card">
        <h3>Seasonal Risk Patterns</h3>
        <div class="chart-container" style="height:300px">
            <canvas id="seasonalChart"></canvas>
        </div>
    </div>
    <div class="chart-card">
        <h3>Zone Risk Timeline (5 Years)</h3>
        <div class="chart-container" style="height:300px">
            <canvas id="zoneRiskChart"></canvas>
        </div>
    </div>
</div>

<!-- Recommendations -->
<div>
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-foreground flex items-center gap-2">
            <i data-lucide="zap" style="width:24px;height:24px;color:var(--primary)"></i>
            AI-Generated Recommendations
        </h2>
        <button class="btn btn-outline btn-sm">
            <i data-lucide="alert-triangle" style="width:16px;height:16px;margin-right:0.5rem"></i> Filter by Priority
        </button>
    </div>
    <div class="space-y-3">
        <!-- Rec 1 -->
        <div class="rec-card high">
            <div class="rec-header">
                <div class="flex-1">
                    <div class="rec-title-row">
                        <h4>Increase patrols in Northern Corridor</h4><span class="badge badge-critical">HIGH</span>
                    </div>
                    <p class="text-sm text-muted">Activity analysis shows 45% increase in poaching attempts during dawn
                        hours</p>
                </div>
            </div>
            <div class="rec-details">
                <div class="flex items-center gap-2"><i data-lucide="map-pin"
                        style="width:16px;height:16px;color:var(--muted-foreground)"></i><span
                        class="font-medium">Northern Corridor</span></div>
                <div>
                    <p class="label">Confidence</p>
                    <div class="flex items-center gap-2">
                        <div class="progress-bar progress-bar-sm" style="flex:1">
                            <div class="progress-fill primary" style="width:92%"></div>
                        </div><span class="text-xs font-semibold">92%</span>
                    </div>
                </div>
                <div>
                    <p class="label">Expected Impact</p><span class="value-success">Could prevent 3-5
                        incidents/month</span>
                </div>
            </div>
            <div class="flex gap-2"><button class="btn btn-outline btn-sm">View Analysis</button><button
                    class="btn btn-outline btn-sm">Implement</button></div>
        </div>

