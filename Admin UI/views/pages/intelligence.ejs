<!-- Pattern Detection -->
<div class="system-status">
    <h3><i data-lucide="bar-chart-3" style="width:20px;height:20px;color:var(--primary)"></i> Pattern Detection</h3>
    <div class="pattern-grid">
        <div class="pattern-item">
            <p class="pattern-label">Coordinated Activity</p>
            <p class="pattern-value text-destructive">7 instances</p>
            <p class="pattern-sub">In past 30 days</p>
        </div>
        <div class="pattern-item">
            <p class="pattern-label">Time-based Clustering</p>
            <p class="pattern-value text-warning">5:00 AM - 7:00 AM</p>
            <p class="pattern-sub">Peak activity window</p>
        </div>
        <div class="pattern-item">
            <p class="pattern-label">Location Correlation</p>
            <p class="pattern-value text-primary">0.84</p>
            <p class="pattern-sub">Water sources</p>
        </div>
        <div class="pattern-item">
            <p class="pattern-label">Anomaly Detection</p>
            <p class="pattern-value text-success">3 new patterns</p>
            <p class="pattern-sub">This month</p>
        </div>
    </div>
