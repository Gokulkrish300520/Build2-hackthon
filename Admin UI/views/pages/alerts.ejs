<!-- Alerts Management Page -->
<div class="page-header">
    <div class="page-header-left">
        <h1><i data-lucide="alert-triangle" style="width:32px;height:32px;color:var(--destructive)"></i> Alerts
            Management</h1>
        <p>Real-time alert monitoring and response coordination</p>
    </div>
    <button class="btn btn-primary">Export Alerts</button>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-4">
    <div class="card card-compact">
        <p class="text-sm text-muted mb-2">Total Alerts</p>
        <p class="text-2xl font-bold text-foreground">8</p>
    </div>
    <div class="card card-compact" style="border-color:rgba(239,68,68,0.3)">
        <p class="text-sm text-destructive mb-2">Critical Active</p>
        <p class="text-2xl font-bold text-destructive">2</p>
    </div>
    <div class="card card-compact">
        <p class="text-sm text-warning mb-2">Acknowledged</p>
        <p class="text-2xl font-bold text-warning">3</p>
    </div>
    <div class="card card-compact">
        <p class="text-sm text-success mb-2">Resolved</p>
        <p class="text-2xl font-bold text-success">3</p>
    </div>
</div>

<!-- Filters -->
<div class="card">
    <div class="filter-bar">
        <div class="filter-group flex-1">
            <label>Search Alerts</label>
            <input type="text" class="input" id="alertSearch" placeholder="Search by title, location, or camera...">
        </div>
        <div class="filter-group">
            <label>Severity</label>
            <div class="btn-group">
                <button class="btn btn-outline btn-sm active" data-severity="all" onclick="filterAlerts()">All</button>
                <button class="btn btn-outline btn-sm" data-severity="critical"
                    onclick="filterAlerts()">Critical</button>
                <button class="btn btn-outline btn-sm" data-severity="warning" onclick="filterAlerts()">Warning</button>
                <button class="btn btn-outline btn-sm" data-severity="info" onclick="filterAlerts()">Info</button>
            </div>
        </div>
        <div class="filter-group">
            <label>Status</label>
            <div class="btn-group">
                <button class="btn btn-outline btn-sm active" data-status="all" onclick="filterAlerts()">All</button>
                <button class="btn btn-outline btn-sm" data-status="active" onclick="filterAlerts()">Active</button>
                <button class="btn btn-outline btn-sm" data-status="acknowledged"
                    onclick="filterAlerts()">Acknowledged</button>
                <button class="btn btn-outline btn-sm" data-status="resolved" onclick="filterAlerts()">Resolved</button>
            </div>
        </div>
        <button class="btn btn-ghost btn-sm" id="clearFilters" onclick="clearAlertFilters()" style="display:none">
            <i data-lucide="x" style="width:16px;height:16px;margin-right:0.5rem"></i> Clear
        </button>
    </div>
</div>

<!-- Alerts List -->
<div>
    <div class="flex items-center justify-between mb-4">
        <p class="result-count" id="alertCount">Showing 8 of 8 alerts</p>
        <button class="btn btn-ghost btn-sm" style="color:var(--primary)">
            <i data-lucide="trending-up" style="width:16px;height:16px;margin-right:0.5rem"></i> Trend Analysis
        </button>
    </div>
    <div class="space-y-3" id="alertsList">
        <!-- Alert cards are generated by JS -->
    </div>
    <div class="card empty-state" id="noAlertsMsg" style="display:none">
        <i data-lucide="filter" style="width:48px;height:48px;color:var(--muted-foreground)"></i>
        <p class="font-semibold text-foreground mb-1">No alerts found</p>
        <p class="text-sm text-muted">Try adjusting your filters or search terms</p>
    </div>
</div>