<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Wildlife Anti-Poaching AI System">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600"
      pageHeight="1200" math="0" shadow="0">

      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start: Camera/Drones Capture Data"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="600" y="40" width="300" height="70" as="geometry"/>
        </mxCell>

        <!-- Data Collection -->
        <mxCell id="data" value="Data Collection&#xa;- Camera traps&#xa;- Drones&#xa;- Environmental Data"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
          vertex="1" parent="1">
          <mxGeometry x="550" y="140" width="400" height="120" as="geometry"/>
        </mxCell>

        <!-- Object Detection -->
        <mxCell id="detect" value="Edge AI (Jetson)&#xa;YOLO Object Detection&#xa;- Animals&#xa;- Humans&#xa;- Weapons/Objects"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;"
          vertex="1" parent="1">
          <mxGeometry x="550" y="300" width="400" height="140" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Human Detected?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="480" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Wildlife Log -->
        <mxCell id="wildlife" value="Log Wildlife Detection&#xa;Store Locally + Send to Cloud"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;"
          vertex="1" parent="1">
          <mxGeometry x="300" y="650" width="350" height="120" as="geometry"/>
        </mxCell>

        <!-- Poacher Classification -->
        <mxCell id="classify" value="Classify Human&#xa;- Authorized Personnel?&#xa;- Suspicious Behavior?&#xa;- Weapon Detection?"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="650" width="400" height="140" as="geometry"/>
        </mxCell>

        <!-- Decision Poacher -->
        <mxCell id="decision2" value="Poacher Detected?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="820" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Alert -->
        <mxCell id="alert" value="Generate Radius-Based Alert&#xa;- 1-3 km zone&#xa;- SMS/App/Mesh&#xa;- Trigger Deterrents"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#990000;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="980" width="400" height="140" as="geometry"/>
        </mxCell>

        <!-- Dashboard -->
        <mxCell id="dashboard" value="Cloud Dashboard&#xa;- Heatmaps&#xa;- Hotspots&#xa;- Risk Zones&#xa;- Historical Logs"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="550" y="1150" width="400" height="140" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" style="endArrow=block;" edge="1" parent="1" source="start" target="data">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=block;" edge="1" parent="1" source="data" target="detect">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=block;" edge="1" parent="1" source="detect" target="decision">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="No" style="endArrow=block;" edge="1" parent="1" source="decision" target="wildlife">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="Yes" style="endArrow=block;" edge="1" parent="1" source="decision" target="classify">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="endArrow=block;" edge="1" parent="1" source="classify" target="decision2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="Yes" style="endArrow=block;" edge="1" parent="1" source="decision2" target="alert">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" value="No (Authorized)" style="endArrow=block;" edge="1" parent="1" source="decision2" target="dashboard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" style="endArrow=block;" edge="1" parent="1" source="alert" target="dashboard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>